rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /public/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/admins).data;
    }
    match /{allPaths=**} {
      allow read;
      allow write: if request.auth != null && root.child('admins').child(request.auth.uid).exists();
    }
  }
}
